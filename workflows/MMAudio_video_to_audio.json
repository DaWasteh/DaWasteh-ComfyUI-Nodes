:"comfyui-videohelpersuite","ver":"0.3.68"},"widgets_values":{"frame_rate":8,"loop_count":0,"filename_prefix":"MMAudio_video","format":"video/h264-mp4","pix_fmt":"yuv420p","crf":19,"save_metadata":true,"trim_to_audio":false,"pingpong":false,"save_output":true,"videopreview":{"hidden":false,"paused":false,"params":{}}}},{"id":7,"type":"Note","pos":[1296.8423312224963,410.41751636792964],"size":[420,460],"flags":{},"order":3,"mode":0,"inputs":[],"outputs":[],"title":"⚙️ Einstellungen","properties":{"Node name for S&R":"Note","cnr_id":"comfy-core","ver":"0.3.68"},"widgets_values":["=== MMAudio (Video -> Audio / Foley) ===\n\nErzeugt synchronen Ton zu einem stummen Video (Schritte,\nUmgebung, Effekte). Analysiert Bildbewegung via Synchformer.\n\nSteps: 25. CFG: 8.0. Duration: in Sekunden (am Sampler).\nPrompt: beschreibt die GEWUENSCHTEN Geraeusche, nicht das Bild.\nNegativ-Prompt optional (z.B. 'music' weglassen).\n\nFILES (alle in models/mmaudio/):\n- mmaudio_large_44k_v2_fp32 (Hauptmodell)\n- mmaudio_vae_44k_fp32 (Audio-VAE)\n- mmaudio_synchformer_fp32 (Bewegungs-Sync)\n- apple_DFN5B-CLIP-ViT-H-14-384 (CLIP)\n\nCustom Nodes: ComfyUI-MMAudio-Suite (Takenoko3333) + VideoHelperSuite.\n44.1kHz Output. Gut fuer LTX/WAN-Clips ohne eigenen Ton."],"color":"#653","bgcolor":"#432"},{"id":8,"type":"MarkdownNote","pos":[1280,40],"size":[400,334.3999938964844],"flags":{},"order":4,"mode":0,"inputs":[],"outputs":[],"title":"📥 Modelle & Downloads","properties":{"Node name for S&R":"MarkdownNote","cnr_id":"comfy-core","ver":"0.3.68"},"widgets_values":["**MMAudio (Video -> Audio / Foley)**\n\nAlle Modelle liegen in `models/mmaudio/`:\n- `mmaudio_large_44k_v2_fp32.safetensors`\n- `mmaudio_vae_44k_fp32.safetensors`\n- `mmaudio_synchformer_fp32.safetensors`\n- `apple_DFN5B-CLIP-ViT-H-14-384_fp32.safetensors`\n\nCustom Nodes: **ComfyUI-MMAudio-Suite** (Takenoko3333), **VideoHelperSuite**.\n\nStummes Video rein -> Ton-Prompt -> synchroner 44kHz-Ton -> mit Video kombiniert."],"color":"#222","bgcolor":"#111"}],"links":[[1,1,0,4,0,"MMAUDIO_MODEL"],[2,2,0,4,1,"MMAUDIO_FEATUREUTILS"],[3,3,0,4,2,"IMAGE"],[4,4,0,5,0,"AUDIO"],[5,3,0,6,0,"IMAGE"],[6,4,0,6,1,"AUDIO"]],"groups":[],"config":{},"extra":{"ds":{"scale":0.9317000000000002,"offset":[345.2355908554248,290.2994526135018]}},"version":0.4}