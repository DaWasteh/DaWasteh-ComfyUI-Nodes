 Mit lightx2v 4-Step-LoRAs: 4 Steps total (2 high + 2 low), CFG=1\n- Ohne LoRAs: 20-30 Steps, CFG 3.5-5\n\nNegativ-Prompt ist der chinesische WAN-Standard (laesst Artefakte weg)."],"color":"#653","bgcolor":"#432"},{"id":19,"type":"MarkdownNote","pos":[40,760],"size":[380,323.3999938964844],"flags":{},"order":6,"mode":0,"inputs":[],"outputs":[],"title":"📥 Modelle & Downloads","properties":{"Node name for S&R":"MarkdownNote","cnr_id":"comfy-core","ver":"0.3.68"},"widgets_values":["**WAN 2.2 I2V 14B fp8 + lightx2v**\n\n- diffusion_models: `WAN/wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors` + `..._low_noise_...`\n- loras: `WAN/wan2.2_i2v_lightx2v_4steps_lora_v1_high_noise.safetensors` + low\n- text_encoders: `UMT5/umt5_xxl_fp8_e4m3fn_scaled.safetensors`\n- vae: `WAN/wan2.2_vae.safetensors`\n\n**4 Steps total, CFG=1.**"],"color":"#222","bgcolor":"#111"}],"links":[[1,1,0,2,0,"MODEL"],[2,2,0,3,0,"MODEL"],[3,4,0,5,0,"MODEL"],[4,5,0,6,0,"MODEL"],[5,7,0,8,0,"CLIP"],[6,7,0,9,0,"CLIP"],[7,11,0,12,0,"VAE"],[8,10,0,12,1,"IMAGE"],[9,3,0,13,0,"MODEL"],[10,8,0,13,1,"CONDITIONING"],[11,9,0,13,2,"CONDITIONING"],[12,12,0,13,3,"LATENT"],[13,6,0,14,0,"MODEL"],[14,8,0,14,1,"CONDITIONING"],[15,9,0,14,2,"CONDITIONING"],[16,13,0,14,3,"LATENT"],[17,14,0,15,0,"LATENT"],[18,11,0,15,1,"VAE"],[19,15,0,16,0,"IMAGE"],[20,16,0,17,0,"VIDEO"]],"groups":[],"config":{},"extra":{"ds":{"scale":0.7,"offset":[740,438.5714285714286]}},"version":0.4}